{
  "name": "@hotwirebits/flow",
  "version": "0.1.0",
  "description": "A React Flow recreation using Hotwire (Stimulus + Tailwind CSS). Build node-based editors with pure HTML.",
  "main": "src/index.js",
  "type": "module",
  "exports": {
    ".": "./src/index.js",
    "./css": "./dist/hotwire-flow.css"
  },
  "files": [
    "src/",
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/DonsWayo/hotwire-flow.git"
  },
  "homepage": "https://donswayo.github.io/hotwire-flow/",
  "keywords": [
    "hotwire",
    "stimulus",
    "flow",
    "react-flow",
    "node-editor",
    "workflow",
    "dag",
    "graph",
    "tailwindcss"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "npx @tailwindcss/cli -i ./src/hotwire-flow.css -o ./dist/hotwire-flow.css --watch",
    "build": "npx @tailwindcss/cli -i ./src/hotwire-flow.css -o ./dist/hotwire-flow.css --minify",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --dir tests/unit",
    "test:integration": "vitest run --dir tests/integration",
    "test:e2e": "npx playwright test",
    "test:all": "npm run test && npm run test:e2e",
    "serve": "npx http-server . -p 3000 -o examples/"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@tailwindcss/vite": "^4.0.0",
    "happy-dom": "^15.0.0",
    "tailwindcss": "^4.0.0",
    "vitest": "^2.0.0",
    "http-server": "^14.1.1"
  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2"
  }
}
